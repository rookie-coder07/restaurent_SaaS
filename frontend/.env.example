# Frontend Environment Variables
# This file is for local development and as a template for Vercel

# API Configuration
# Production: Your Render backend URL
# Development: Local backend URL
VITE_API_BASE_URL=http://localhost:3000/api
NEXT_PUBLIC_API_URL=https://restaurent-backend-448t.onrender.com/api

# Frontend URL (for QR code generation)
# Production: Will be automatically set by Vercel via VERCEL_URL
# Development: Local frontend URL
VITE_FRONTEND_URL=http://localhost:5173

# Third-party services
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_name

# App Info
VITE_APP_NAME=Restaurant Management SaaS

# Supabase (if using)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Frontend Environment Variables
# This file is the shared template. For local frontend work, prefer `.env.local`.

# API Configuration
VITE_API_URL=https://restaurent-backend-448t.onrender.com/api/v1

# Frontend URL (for QR code generation)
# Production: Set this to your permanent public domain, not a Vercel preview URL
# Development: Local frontend URL
VITE_FRONTEND_URL=http://localhost:5173

# App URL (for password reset redirects and auth flows)
# CRITICAL: Use your actual production domain (e.g., https://app.yourdomain.com)
# DO NOT use localhost URLs in production
# This must match Supabase Site URL setting
VITE_APP_URL=http://localhost:5173

# Optional debug logging in local development
VITE_DEBUG_API=false

# Third-party services
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_name

# App Info
VITE_APP_NAME=Restaurant Management SaaS

# Supabase (if using)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Local frontend development
# Copy this file to `.env.local` when running the frontend on your machine.

# Local backend API
VITE_API_BASE_URL=http://localhost:3000/api

# Local frontend URL for QR generation
VITE_FRONTEND_URL=http://localhost:5173

# Optional: enable noisy API request/response logs in the browser console
VITE_DEBUG_API=false
